<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="
 http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="AddrId" class="in.cg.beans.Address">
        <property name="hno" value="1002"/>
        <property name="city" value="Deoria"/>
        <property name="pincode" value="274501"/>
    </bean>
    
    <bean id="StdId" class="in.cg.beans.Student">
        <property name="id" value="1002"/>
        <property name="name" value="Akhilesh"/>
        <property name="email" value="akp03112000@gmail.com"/>
        <property name="a" ref="AddrId"/>
    </bean>
    

</beans>